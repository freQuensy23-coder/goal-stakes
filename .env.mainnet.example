# Backend
HTTP_PORT=8080
DATABASE_URL=postgres://goalstakes:goalstakes@localhost:5432/goalstakes?sslmode=disable
JWT_SECRET=replace-with-a-long-random-secret
SIWE_DOMAIN=app.example.com
SESSION_TTL=24h
SCHEDULER_INTERVAL=1m
PUBLIC_BASE_URL=https://api.example.com

# AI goal manager.
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_TRANSCRIPTION_MODEL=
OPENAI_BASE_URL=
OPENAI_VERIFY_TIMEOUT=30s

# Enables real StakeEnforcer.penalize calls and live ERC-20 allowance reads.
ENFORCER_PRIVATE_KEY=
# Do not set ALLOW_DISABLED_ENFORCER for mainnet go-live.

# Replace the StakeEnforcer placeholders after deploying web3/script/Deploy.s.sol
# on Ethereum and Polygon. The placeholders are intentionally not valid
# addresses, so the backend fails fast until deployment addresses are inserted.
CHAINS_JSON='{"ethereum":{"rpc_url":"https://mainnet.infura.io/v3/<key>","stake_enforcer_address":"<ethereum-stake-enforcer-address>","tokens":{"USDC":"0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48","USDT":"0xdAC17F958D2ee523a2206206994597C13D831ec7"}},"polygon":{"rpc_url":"https://polygon-mainnet.infura.io/v3/<key>","stake_enforcer_address":"<polygon-stake-enforcer-address>","tokens":{"USDC":"0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359","USDT":"0xc2132D05D31c914a87C6611C10748AEb04B58e8F"}}}'

# Frontend
VITE_API_BASE_URL=https://api.example.com

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_SECRET=
GOALSTAKES_API_BASE=https://api.example.com
TELEGRAM_POLL_TIMEOUT_SECONDS=30

# Optional live e2e burn test. Use a sacrificial wallet and tiny base-unit amount.
# `1` is 0.000001 USDC/USDT. The script rejects amounts above LIVE_E2E_MAX_AMOUNT.
LIVE_E2E_USER_WALLET=
LIVE_E2E_CHAIN=polygon
LIVE_E2E_TOKEN_SYMBOL=USDC
LIVE_E2E_AMOUNT=1
LIVE_E2E_MAX_AMOUNT=10000
LIVE_E2E_TIMEOUT=5m
# Optional. When set, burn mode tests this already-running API and does not
# start a local server. DATABASE_URL must point at the same database so the
# harness can seed and revoke its temporary API key. When empty, burn mode
# starts a local API with this live config at http://127.0.0.1:$HTTP_PORT.
LIVE_E2E_API_BASE=
# Must be exactly `burn-real-funds` to run scripts/e2e-live-mainnet.sh burn.
LIVE_E2E_CONFIRM=
