# Backend
HTTP_PORT=8080
DATABASE_URL=postgres://goalstakes:goalstakes@localhost:5433/goalstakes?sslmode=disable
JWT_SECRET=replace-with-a-long-random-secret
SIWE_DOMAIN=127.0.0.1:5173
SESSION_TTL=24h
SCHEDULER_INTERVAL=1m
PUBLIC_BASE_URL=http://127.0.0.1:8080

# Optional: enables the AI goal manager.
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_TRANSCRIPTION_MODEL=
OPENAI_BASE_URL=

# Optional: enables real on-chain penalties and live ERC-20 allowance reads.
# Keep empty only for local UI/API work; approvals then require tx_hash plus
# dry_run_allowance because the backend cannot read live allowance.
ENFORCER_PRIVATE_KEY=

# Local/dry-run only. Leave unset for real Ethereum/Polygon launches.
ALLOW_DISABLED_ENFORCER=

# Testnet-first chain config. Replace placeholder addresses with deployed testnet contracts.
# For Ethereum/Polygon mainnet, start from .env.mainnet.example instead.
CHAINS_JSON='{"sepolia":{"rpc_url":"https://sepolia.example/rpc","stake_enforcer_address":"0x1111111111111111111111111111111111111111","tokens":{"USDC":"0x2222222222222222222222222222222222222222","USDT":"0x3333333333333333333333333333333333333333"}},"polygon-amoy":{"rpc_url":"https://amoy.example/rpc","stake_enforcer_address":"0x4444444444444444444444444444444444444444","tokens":{"USDC":"0x5555555555555555555555555555555555555555","USDT":"0x6666666666666666666666666666666666666666"}}}'

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8080

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_SECRET=
GOALSTAKES_API_BASE=http://127.0.0.1:8080
TELEGRAM_POLL_TIMEOUT_SECONDS=30
